<?xml version="1.0" encoding="utf-8"?>
<!--
  PlayerView en TEXTURE_VIEW (et non SurfaceView) : la TextureView s'anime comme une vue normale,
  ce qui évite le flash noir / la frame résiduelle lors des transitions de navigation (sortie de
  session). Léger surcoût mémoire/batterie, acceptable ici (pas de DRM).
-->
<androidx.media3.ui.PlayerView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:keepScreenOn="true"
    app:surface_type="texture_view"
    app:use_controller="true"
    app:show_subtitle_button="true"
    app:show_next_button="false"
    app:show_previous_button="false" />
