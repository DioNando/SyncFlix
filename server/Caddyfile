# Reverse proxy SyncFlix — fusionne HTTP (Laravel), WebSocket (Reverb) et streaming vidéo
# sur un seul port, pour n'exposer qu'UN tunnel ngrok. (Voir ARCHITECTURE.md.)
#
# Lancement : caddy run   (depuis server/)
# Topologie  : ngrok http 8088  →  Caddy :8088  ┬─ /media/* → fichiers vidéo (file_server, Range natif)
#                                               ├─ /app/*   → Reverb  127.0.0.1:8080  (WebSocket)
#                                               └─ reste    → Laravel 127.0.0.1:8000  (API REST)
#
# Pourquoi /media/* en file_server : `php artisan serve` est mono-thread ; faire transiter un gros
# fichier (.mkv de plusieurs Go) par PHP bloque l'unique worker et empêche un 2e spectateur de
# rejoindre (join/auth WS en attente derrière le flux). Caddy sert le fichier nativement, en
# parallèle et avec gestion du Range, laissant PHP libre pour l'API.
#
# TLS : inutile ici — ngrok termine le HTTPS/WSS à sa frontière et transmet du HTTP clair à Caddy.

{
	# Pas de HTTPS automatique : on sert en HTTP clair derrière ngrok.
	auto_https off
}

:8088 {
	# Streaming vidéo : sert les liens « propres » id.ext créés par `movies:scan` (Range natif,
	# multi-thread). On sert depuis storage/app/private/media (liens) et NON movies/ : l'URL ne
	# contient ainsi que /media/{id}.{ext} → aucun caractère spécial (les crochets/parenthèses des
	# noms de release faisaient échouer Caddy en 404).
	handle_path /media/* {
		root * storage/app/private/media
		file_server
	}

	# Connexions WebSocket Reverb : le client Pusher se connecte sur /app/{clé}.
	handle /app/* {
		reverse_proxy 127.0.0.1:8080
	}

	# Tout le reste → Laravel (API REST + sous-titres).
	handle {
		reverse_proxy 127.0.0.1:8000
	}
}
